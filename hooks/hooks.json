{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/incarnate.js\"",
            "commandWindows": "node \"%CLAUDE_PLUGIN_ROOT%\\hooks\\incarnate.js\"",
            "timeout": 5,
            "statusMessage": "Incarnating the Fable voice..."
          }
        ]
      }
    ]
  }
}
